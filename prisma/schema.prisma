generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

enum SourceName {
  NET_A_PORTER
  MR_PORTER
}

enum Gender {
  WOMEN
  MEN
}

enum JobStatus {
  NOT_STARTED
  QUEUED
  PARSING_CATEGORY_PAGES
  PARSING_PRODUCT_PAGES
  DOWNLOADING_IMAGES
  PROCESSING_IMAGES
  READY_FOR_PREVIEW
  IMPORTING
  IMPORTED
  PARTIAL
  ERROR
}

enum ImportStatus {
  DRAFT
  READY
  IMPORTED
  ERROR
  SKIPPED
}

model Shop {
  id          String   @id @default(cuid())
  shop        String   @unique
  accessToken String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SourceCategory {
  id               String    @id @default(cuid())
  source           SourceName
  gender           Gender
  category         String
  url              String
  pages            Int
  expectedResults  Int
  collectedResults Int       @default(0)
  status           JobStatus @default(NOT_STARTED)
  lastRunAt        DateTime?
  products         Product[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model Product {
  id               String          @id @default(cuid())
  source           SourceName
  gender           Gender
  category         String
  brand            String?
  title            String
  price            Float?
  compareAtPrice   Float?
  currency         String          @default("EUR")
  color            String?
  sizes            Json?
  description      String?
  composition      String?
  sku              String?
  sourceUrl        String          @unique
  imageUrls        Json?
  originalImages   Json?
  processedImage   String?
  shopifyProductId String?
  importStatus     ImportStatus    @default(DRAFT)

  categorySourceId String?
  categorySource   SourceCategory? @relation(fields: [categorySourceId], references: [id])

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model ParseRun {
  id               String    @id @default(cuid())
  source           SourceName
  category         String
  status           JobStatus @default(QUEUED)
  expectedResults  Int
  collectedResults Int       @default(0)
  message          String?
  startedAt        DateTime  @default(now())
  finishedAt       DateTime?
}