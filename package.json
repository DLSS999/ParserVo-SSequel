{
  "name": "parservo-v3",
  "version": "3.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.4",
  "scripts": {
    "dev": "shopify app dev",
    "build": "prisma generate && react-router build",
    "vercel-build": "prisma generate && react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "setup": "prisma generate && prisma db push",
    "db:deploy": "prisma db push",
    "typecheck": "react-router typegen && tsc --noEmit"
  },
  "engines": { "node": "22.x", "npm": "10.x" },
  "dependencies": {
    "@prisma/client": "6.16.3",
    "@react-router/dev": "7.12.0",
    "@react-router/fs-routes": "7.12.0",
    "@react-router/node": "7.12.0",
    "@react-router/serve": "7.12.0",
    "@shopify/app-bridge-react": "4.2.4",
    "@shopify/shopify-app-react-router": "1.1.0",
    "@shopify/shopify-app-session-storage-prisma": "9.0.0",
    "@vercel/react-router": "1.2.2",
    "isbot": "5.1.31",
    "prisma": "6.16.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router": "7.12.0",
    "vite-tsconfig-paths": "5.1.4",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@shopify/api-codegen-preset": "2.0.0",
    "@shopify/polaris-types": "1.0.1",
    "@types/node": "22.10.2",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "typescript": "5.7.2",
    "vite": "6.0.7"
  }
}
