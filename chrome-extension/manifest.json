{
  "manifest_version": 3,
  "name": "ParserVo Stone Island Capture",
  "version": "2.9.5",
  "description": "Stone Island capture with compact payloads, transport retries, factual LOAD MORE completion, colour expansion, stock audit and emergency stop.",
  "permissions": ["activeTab", "alarms", "scripting", "storage", "tabs"],
  "host_permissions": [
    "https://*.stoneisland.com/*",
    "https://stoneisland.com/*",
    "https://*.vercel.app/*",
    "https://*.myshopify.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": { "service_worker": "background-entry-295.js" },
  "action": {
    "default_title": "ParserVo Stone Island Capture",
    "default_popup": "popup.html"
  }
}
